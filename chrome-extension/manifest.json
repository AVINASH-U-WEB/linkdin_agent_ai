{
  "manifest_version": 3,
  "name": "LinkedIn AI Autopilot Extractor",
  "version": "1.0",
  "description": "Extracts your LinkedIn posts and sends them to your local AI Intelligence dashboard.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI LinkedIn Autopilot"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"]
    }
  ]
}
